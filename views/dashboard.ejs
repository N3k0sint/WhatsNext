<%- include('partials/header') %>

<div class="row mb-2">
  <div class="col">
    <h2 class="dashboard-title">Workspace Dashboard</h2>
  </div>
</div>

<div class="row">
  <!-- Create Task Form -->
  <div class="col-lg-3 col-md-4 mb-4">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider">New Task</h6>
      </div>
      <div class="card-body">
        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% errors.forEach(err => { %>
                <li><%= err.msg %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>
        <form action="/tasks?_csrf=<%= csrfToken %>" method="POST" enctype="multipart/form-data">
          <!-- Anti-CSRF Token -->
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          
          <div class="mb-3">
            <label for="title" class="form-label">Task Title</label>
            <input type="text" class="form-control" id="title" name="title" required>
          </div>
          <div class="mb-3">
            <label for="description" class="form-label">Description (Optional)</label>
            <textarea class="form-control" id="description" name="description" rows="3"></textarea>
          </div>
          <div class="mb-3">
            <label for="attachment" class="form-label">Attachment (PDF/Img, Max 10MB)</label>
            <input class="form-control" type="file" id="attachment" name="attachment" accept=".pdf,.jpg,.jpeg,.png">
            <div class="form-text">Files will be renamed to a secure UUID.</div>
          </div>
          <button type="submit" class="btn btn-primary w-100">Add Task</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Task List -->
  <div class="col-lg-9 col-md-8">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider">Project Backlog</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Attachment</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (tasks.length === 0) { %>
                <tr>
                  <td colspan="4" class="text-center py-4">No tasks found. Create one!</td>
                </tr>
              <% } else { %>
                <% tasks.forEach(task => { %>
                  <tr>
                    <td>
                      <strong><%= task.title %></strong><br>
                      <small class="text-muted"><%= task.description %></small>
                    </td>
                    <td>
                      <span class="badge <%= task.status === 'Completed' ? 'bg-success' : 'bg-warning text-dark' %>">
                        <%= task.status %>
                      </span>
                    </td>
                    <td>
                      <% if (task.attachmentPath) { %>
                        <a href="/tasks/download/<%= task.attachmentPath %>" class="btn btn-sm btn-outline-info" target="_blank">Download</a>
                      <% } else { %>
                        <span class="text-muted">None</span>
                      <% } %>
                    </td>
                    <td>
                      <div class="d-flex gap-2">
                        <form action="/tasks/<%= task.id %>/status" method="POST">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-outline-secondary">
                            Toggle Status
                          </button>
                        </form>
                        <form action="/tasks/<%= task.id %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this task?');">
                          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
