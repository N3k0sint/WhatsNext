<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-header bg-primary text-white">
        <h4 class="mb-0">System Error</h4>
      </div>
      <div class="card-body text-center">
        <h1 class="display-1 text-danger"><%= status %></h1>
        <h3><%= message %></h3>
        <p class="text-muted mt-3">Stack traces are intentionally suppressed for security purposes.</p>
        <a href="/" class="btn btn-outline-primary mt-3">Return to Home</a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
