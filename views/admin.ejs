<%- include('partials/header') %>

<!-- Bootstrap Confirm Modal for Delete -->
<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to <strong>permanently delete</strong> user <strong id="deleteUserName"></strong> and all their tasks? This cannot be undone.
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="confirmDeleteBtn">Yes, Delete</button>
      </div>
    </div>
  </div>
</div>

<!-- Bootstrap Confirm Modal for Edit -->
<div class="modal fade" id="editConfirmModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title"><i class="bi bi-pencil-fill me-2"></i>Confirm Edit</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        Are you sure you want to edit user <strong id="editUserName"></strong>?
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="confirmEditBtn">Yes, Edit</button>
      </div>
    </div>
  </div>
</div>

<!-- Hidden delete form — submitted by admin.js -->
<form id="deleteUserForm" method="POST" style="display:none;">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
</form>

<div class="row mb-3">
  <div class="col">
    <h2 class="dashboard-title">System Administration</h2>
  </div>
</div>

<!-- Admin Quick Insights -->
<div class="row mb-4">
  <div class="col-md-4">
    <div class="card border-0 bg-white text-center py-3">
      <div class="small text-muted text-uppercase fw-bold">Active Users</div>
      <div class="h3 mb-0 fw-bold text-primary"><%= users.length %></div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 bg-white text-center py-3">
      <div class="small text-muted text-uppercase fw-bold">System Status</div>
      <div class="h3 mb-0 fw-bold text-success">Healthy</div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card border-0 bg-white text-center py-3">
      <div class="small text-muted text-uppercase fw-bold">Security Level</div>
      <div class="h3 mb-0 fw-bold text-danger">Strict</div>
    </div>
  </div>
</div>

<!-- Audit Logs -->
<div class="row">
  <div class="col-md-12 mb-4">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider text-danger">Security Audit Logs</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover table-striped table-sm mb-0">
            <thead class="table-dark">
              <tr>
                <th>Time</th><th>Action</th><th>Username</th><th>IP Address</th><th>Details</th>
              </tr>
            </thead>
            <tbody>
              <% if (logs.length === 0) { %>
                <tr><td colspan="5" class="text-center">No logs recorded.</td></tr>
              <% } else { %>
                <% logs.forEach(log => { %>
                  <tr>
                    <td><%= new Date(log.createdAt).toLocaleString() %></td>
                    <td>
                      <span class="badge <%= log.action.includes('FAILED') ? 'bg-danger' : 'bg-info text-dark' %>">
                        <%= log.action %>
                      </span>
                    </td>
                    <td><%= log.username || 'Unknown' %></td>
                    <td><%= log.ipAddress %></td>
                    <td><small><%= log.details %></small></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Active Directory -->
<div class="row">
  <div class="col-md-12">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider">Active Directory</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>ID</th><th>Username</th><th>Role</th><th>Joined Date</th><th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => { %>
                <tr>
                  <td><%= u.id %></td>
                  <td><strong><%= u.username %></strong></td>
                  <td>
                    <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-primary' %>">
                      <%= u.role.toUpperCase() %>
                    </span>
                  </td>
                  <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                  <td>
                    <div class="d-flex gap-2">
                      <button type="button"
                        class="btn btn-sm btn-outline-primary"
                        data-action="edit"
                        data-user-id="<%= u.id %>"
                        data-username="<%= u.username %>">
                        Edit
                      </button>
                      <% if (locals.user && locals.user.id !== u.id) { %>
                        <button type="button"
                          class="btn btn-sm btn-danger"
                          data-action="delete"
                          data-user-id="<%= u.id %>"
                          data-username="<%= u.username %>">
                          Delete
                        </button>
                      <% } else { %>
                        <button class="btn btn-sm btn-secondary" disabled>Delete</button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>

<!-- Load AFTER footer so Bootstrap JS is available -->
<script src="/js/admin.js"></script>
