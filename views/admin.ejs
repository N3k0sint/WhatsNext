<%- include('partials/header') %>

<div class="row mb-2">
  <div class="col">
    <h2 class="dashboard-title">System Administration</h2>
  </div>
</div>

<div class="row">
  <div class="col-md-12 mb-4">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider text-danger">Security Audit Logs</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover table-striped table-sm mb-0">
            <thead class="table-dark">
              <tr>
                <th>Time</th>
                <th>Action</th>
                <th>Username</th>
                <th>IP Address</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              <% if (logs.length === 0) { %>
                <tr><td colspan="5" class="text-center">No logs recorded.</td></tr>
              <% } else { %>
                <% logs.forEach(log => { %>
                  <tr>
                    <td><%= new Date(log.createdAt).toLocaleString() %></td>
                    <td>
                      <span class="badge <%= log.action.includes('FAILED') ? 'bg-danger' : 'bg-info text-dark' %>">
                        <%= log.action %>
                      </span>
                    </td>
                    <td><%= log.username || 'Unknown' %></td>
                    <td><%= log.ipAddress %></td>
                    <td><small><%= log.details %></small></td>
                  </tr>
                <% }) %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-12">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider">Active Directory</h6>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead>
              <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Role</th>
                <th>Joined Date</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="userTableBody">
              <% users.forEach(u => { %>
                <tr>
                  <td><%= u.id %></td>
                  <td><strong><%= u.username %></strong></td>
                  <td>
                    <span class="badge <%= u.role === 'admin' ? 'bg-danger' : 'bg-primary' %>">
                      <%= u.role.toUpperCase() %>
                    </span>
                  </td>
                  <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                  <td>
                    <div class="d-flex gap-2">
                      <a href="/admin/users/<%= u.id %>/edit" class="btn btn-sm btn-outline-primary" onclick="return confirm('Are you sure you want to edit this user?');">Edit</a>
                      <% if (locals.user && locals.user.id !== u.id) { %>
                        <form action="/admin/users/<%= u.id %>/delete?_csrf=<%= csrfToken %>" method="POST" onsubmit="return confirm('Are you sure you want to completely delete this user and all their tasks?');">
                          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                      <% } else { %>
                        <button class="btn btn-sm btn-secondary" disabled title="Cannot delete yourself">Delete</button>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // Real-time AJAX Polling for User Management
  setInterval(() => {
    fetch('/admin/api/users')
      .then(res => res.json())
      .then(users => {
        const tbody = document.getElementById('userTableBody');
        tbody.innerHTML = ''; // clear current rows
        
        users.forEach(u => {
          const joinedDate = new Date(u.createdAt).toLocaleDateString();
          const roleBadgeClass = u.role === 'admin' ? 'bg-danger' : 'bg-primary';
          const roleText = u.role.toUpperCase();
          
          let actionButtons = `<a href="/admin/users/${u.id}/edit" class="btn btn-sm btn-outline-primary" onclick="return confirm('Are you sure you want to edit this user?');">Edit</a>`;
          
          // Current logged in user ID is available via <%= locals.user.id %>
          const currentUserId = <%= locals.user ? locals.user.id : -1 %>;
          
          if (currentUserId !== u.id) {
            actionButtons += `
              <form action="/admin/users/${u.id}/delete?_csrf=<%= csrfToken %>" method="POST" class="d-inline" onsubmit="return confirm('Are you sure you want to completely delete this user and all their tasks?');">
                <button type="submit" class="btn btn-sm btn-danger ms-2">Delete</button>
              </form>
            `;
          } else {
            actionButtons += `<button class="btn btn-sm btn-secondary ms-2" disabled title="Cannot delete yourself">Delete</button>`;
          }

          tbody.innerHTML += `
            <tr>
              <td>${u.id}</td>
              <td><strong>${u.username}</strong></td>
              <td><span class="badge ${roleBadgeClass}">${roleText}</span></td>
              <td>${joinedDate}</td>
              <td>
                <div class="d-flex align-items-center">
                  ${actionButtons}
                </div>
              </td>
            </tr>
          `;
        });
      })
      .catch(err => console.error('Error polling users:', err));
  }, 3000); // Poll every 3 seconds
</script>

<%- include('partials/footer') %>
