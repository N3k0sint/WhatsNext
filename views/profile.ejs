<%- include('partials/header') %>

<div class="row justify-content-center mb-4">
  <div class="col-md-6 col-lg-5">
    <div class="card border-0">
      <div class="card-header border-bottom">
        <h6 class="mb-0 text-uppercase small tracking-wider">Account Settings</h6>
      </div>
      <div class="card-body">
        
        <% if (errors && errors.length > 0) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% errors.forEach(err => { %>
                <li><%= err.msg %></li>
              <% }) %>
            </ul>
          </div>
        <% } %>

        <div class="text-center mb-4">
          <div class="display-1 text-info mb-2">
            <i class="bi bi-person-circle"></i>
          </div>
          <h3><%= locals.user ? locals.user.username : 'User' %></h3>
          <span class="badge <%= locals.user && locals.user.role === 'admin' ? 'bg-danger' : 'bg-primary' %>">
            <%= locals.user ? locals.user.role.toUpperCase() : 'USER' %>
          </span>
        </div>

        <hr>

        <h5 class="mb-3">Edit Profile</h5>
        <form action="/profile/edit?_csrf=<%= csrfToken %>" method="POST" onsubmit="return confirm('Are you sure you want to change your username?');">
          <div class="mb-3">
            <label for="username" class="form-label">Username</label>
            <input type="text" class="form-control" id="username" name="username" value="<%= locals.user ? locals.user.username : '' %>" required>
          </div>
          <button type="submit" class="btn btn-primary w-100 mb-3">Update Username</button>
        </form>

        <hr>

        <h5 class="mb-3 text-danger">Change Password</h5>
        <form action="/profile/password?_csrf=<%= csrfToken %>" method="POST" onsubmit="return confirm('Are you sure you want to change your password?');">
          <div class="mb-3">
            <label for="currentPassword" class="form-label">Current Password</label>
            <input type="password" class="form-control" id="currentPassword" name="currentPassword" required>
          </div>
          <div class="mb-3">
            <label for="newPassword" class="form-label">New Password</label>
            <input type="password" class="form-control" id="newPassword" name="newPassword" required minlength="8">
            <div class="form-text">Min 8 characters, with uppercase, lowercase, number, and special character.</div>
          </div>
          <button type="submit" class="btn btn-danger w-100">Change Password</button>
        </form>

      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
